{
    "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
    "outputDirectory": "frontend/.next",
    "installCommand": "echo 'skip root install'",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://lost-found-79xn.onrender.com/api/:path*"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "https://lost-found-79xn.onrender.com/socket.io/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://lost-found-79xn.onrender.com/uploads/:path*"
        }
    ]
}