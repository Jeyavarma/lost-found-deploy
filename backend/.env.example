# ============================================
# MCC LOST & FOUND - ENVIRONMENT CONFIGURATION
# ============================================
# SECURITY WARNING: Never commit .env file to git!
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

NODE_ENV=production

# ─── CORS Configuration ─────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,https://your-app.vercel.app

# ─── Rate Limiting ──────────────────────────
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ─── File Upload ────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ─── JWT Configuration ──────────────────────
# CRITICAL: Generate a strong random secret (min 32 chars)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<generate-random-secret-here>
JWT_EXPIRES_IN=7d

# ─── Database ───────────────────────────────
# CRITICAL: Never expose database credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# ─── Redis Cache ────────────────────────────
REDIS_URL=redis://<username>:<password>@<host>:<port>

# ─── Cloudinary (Image Storage) ─────────────
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ─── Email Service (EmailJS) ────────────────
EMAILJS_SERVICE_ID=<your-service-id>
EMAILJS_TEMPLATE_ID=<your-template-id>
EMAILJS_PUBLIC_KEY=<your-public-key>
EMAILJS_PRIVATE_KEY=<your-private-key>
EMAIL_USER=<your-email>

# ─── Google OAuth (Optional) ────────────────
GOOGLE_CLIENT_ID=<your-client-id>
GOOGLE_CLIENT_SECRET=<your-client-secret>
GOOGLE_REFRESH_TOKEN=<your-refresh-token>

# ─── Firebase Storage (Fallback) ────────────
FIREBASE_PROJECT_ID=<your-project-id>
FIREBASE_CLIENT_EMAIL=<your-service-account-email>
FIREBASE_PRIVATE_KEY=<your-private-key>
FIREBASE_STORAGE_BUCKET=<your-bucket>

# ─── Web Push Notifications ─────────────────
VAPID_PUBLIC_KEY=<your-public-key>
VAPID_PRIVATE_KEY=<your-private-key>
VAPID_SUBJECT=mailto:<your-email>

# ─── Email Service (Resend) ─────────────────
RESEND_API_KEY=<your-api-key>

# ─── Server Port ────────────────────────────
PORT=10000
