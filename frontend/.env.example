# ============================================
# FRONTEND ENVIRONMENT CONFIGURATION
# ============================================
# SECURITY: Only NEXT_PUBLIC_* variables are exposed to browser
# Never put secrets in NEXT_PUBLIC_* variables!

# ─── Backend API ────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com
BACKEND_URL=https://your-backend.onrender.com

# ─── Cloudinary (Public only) ───────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your-cloud-name>
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=<your-preset>

# ─── EmailJS (Public keys only) ─────────────
NEXT_PUBLIC_EMAILJS_SERVICE_ID=<your-service-id>
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=<your-template-id>
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=<your-public-key>

# ─── Push Notifications (Public key only) ───
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<your-vapid-public-key>

# ─── Auth Storage Keys ──────────────────────
NEXT_PUBLIC_AUTH_TOKEN_KEY=mcc_auth_token
NEXT_PUBLIC_USER_DATA_KEY=mcc_user_data

# ─── Chat Configuration ─────────────────────
NEXT_PUBLIC_QUEUE_STORAGE_KEY=chat_message_queue
NEXT_PUBLIC_MAX_RETRIES=3
NEXT_PUBLIC_MAX_QUEUE_SIZE=100
NEXT_PUBLIC_MAX_MESSAGE_AGE=86400000

# ─── Analytics ──────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Feature Flags ──────────────────────────
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SECURITY_HEADERS=true
